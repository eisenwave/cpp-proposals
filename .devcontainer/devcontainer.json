{
  "name": "cpp-proposals",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "files.associations": {
          "*.cow": "cowel",
          "*.cowel": "cowel"
        }
      }
    }
  },
  "postCreateCommand": "bash -lc 'npm install -g cowel@0.9.1 && curl -fsSL -o /tmp/cowel-language-support-0.9.1.vsix https://github.com/eisenwave/cowel/releases/download/v0.9.1/cowel-language-support-0.9.1.vsix && code --install-extension /tmp/cowel-language-support-0.9.1.vsix --force'"
}
