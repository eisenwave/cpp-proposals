\slide{
\slideh{P3568R2 strategy}

\ul{
  \li{labels can go \em{anywhere}, even multiple times}
  \li{restrict \tcode{goto}, \tcode{break}, \tcode{continue}, not labels}
}
\cppblock{
label: label: while (true) break label; // OK
label: for (/* ... */) continue label;  // OK

goto label;               // error: jump to duplicate label
while (true) break label; // error: break of unrelated loop
}

\ul{
  \li{\b{Idea}: labels are \em{basically} comments, so why restrict them?}
  \li{\b{Benefit}: very simple, teachable system}
}
}

\slide{
\slideh{Summary}

\ul{
  \li{✅ EWG wants \tcode{break label}, and we have a design}
  \li{✅ syntax debate in WG14 is resolved}
  \li{✅ label problems are resolved (both in WG14 and in P3568R2)}
  \li{✅ wording exists, CWG chair looked at it}
  \li{
    implementation non-trivial, but possible
    \ul{
      \li{GCC and Clang implement N3355 in C mode}
      \li{no implementation in C++ mode yet}
      \li{Clang implementers convinced that \tcode{break label} is feasible}
    }
  }
}

}
