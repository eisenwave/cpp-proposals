}

\slide{
\slideh{Proposed design}

\style{
#design {
    font-size: 90%;
}
}

\div(id="design"){
\cppblock{
template<\exposid{unsigned-integer} T>
  T clmul(T x, T y) noexcept;

template<class T>
struct wide_result {
  T low_bits, high_bits;
  // comparison operators ...
};

template<\exposid{unsigned-integer} T> // See also P4052R0 for naming rationale:
  constexpr wide_result<T> widening_clmul(T x, T y) noexcept;
}
\ul{
\li{\tcode{clmul} names used because it is most common (Intel, LLVM, RV64, etc.)}
\li{\tcode{simd::clmul} also provided (but no \tcode{simd::widening_clmul})}
}
}
}

\slide{
\slideh{Implementation and wording}

\style{
.no-vertical-margin {
    margin-top: 0;
    margin-bottom: 0;
}
}

\cowel_html_element("h4", attr=(class="false-vertical-margin")){Implementation}
\ul(class="false-vertical-margin"){
  \li{naive fallback implementation is trivial}
  \li{
    good implementation difficult
    (dispatch to CPU instructions,
    advanced algorithms for software impl.,
    special cases when one operand is known)
  }
  \li{LLVM 23 instruction: \tt{@llvm.clmul}}
  \li{Clang 23 builtin: \tt{__builtin_elementwise_clmul}}
}

\cowel_html_element("h4", attr=(class="false-vertical-margin")){Wording}
\ul{
  \li{reviewed by SG6 for correctness; \i{see paper}}
}
}

