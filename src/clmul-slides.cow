\cowel_html_element("h1"){Carry-less product:\br\tcode{std::clmul}\br
\span(id="docnum"){P3642R5}}
}

\slide{
\slideh{Introduction}

\style{
#tony-table {
    margin-left: auto;
    margin-right: auto;
    width: 90%;
    table-layout: fixed;
}
#tony-table td {
    background-color: var(--deep-background-color);
    width: 50%;
}
#tony-table code-block {
    margin: 0.25em auto;
    width: fit-content;
}
}

\b{Intuition}: "carry-less" means we use XOR instead of plus.

\table(id="tony-table"){
\tr{
    \th{Regular multiplication}
    \th{Carry-less multiplication}
}
\tr{
\td{\codeblock("cpp",borders=false){
\comment{}     x * 0b0110
== \tt{(x << 3) * 0}
 + (x << 2) * 1
 + (x << 1) * 1
 + (x << 0) * 0
}}
\td{\codeblock("cpp",borders=false){
clmul(x, 0b0110)
 == \tt{(x << 3) * 0}
  ^ (x << 2) * 1
  ^ (x << 1) * 1
  ^ (x << 0) * 0
}}
}
}
\ul{
\li{useful for CRC, AES-GCM, parsing, bit manipulation, \'HORIZONTAL ELLIPSIS'}
\li{widespread hardware support (x86_64, ARM, RISC-V)}
\li{a.k.a. "polynomial multiplication" and "XOR multiplication"}
}
}

\slide{
\slideh{Motivating example}

\ul{
\li{\tcode{clmul(x, -1u)} computes \dfn{bitwise parity} (inclusive)}
\li{i.e. for each bit in \tcode{x}, \tcode{/* \serif{is 1-bit count to right odd?} */ ? 1 : 0}}
\li{can be used to check if character is inside/outside string in parallel}
}
\pre{
abc xxx \code("cpp",nested=true){"foobar"} zzz \code("cpp",nested=true){"a"}
00000000\hl("string-delim"){1}\hl("string"){000000}\hl("string-delim"){1}00000\hl("string-delim"){1}\hl("string"){0}\hl("string-delim"){1} \code("cpp",nested=true){// quotes}
00000000\hl("string-delim"){0}\hl("string"){111111}\hl("string-delim"){1}00000\hl("string-delim"){0}\hl("string"){1}\hl("string-delim"){1} \code("cpp",nested=true){// clmul(quotes, -1u)}
00000000\hl("string-delim"){0}\hl("string"){111111}\hl("string-delim"){0}00000\hl("string-delim"){0}\hl("string"){1}\hl("string-delim"){0} \code("cpp",nested=true){// clmul(quotes, -1u) & ~quotes}
}

This technique is used to accelerate string parsing in \tt{simdjson}.
}

